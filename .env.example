# ───────────────────────────────────────────────────────────────────────────
#  Esmi — environment template (Phase 1)
#  Copy to `.env`, fill in values, NEVER commit. `.env` is already gitignored.
# ───────────────────────────────────────────────────────────────────────────

# ── OpenAI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Google Calendar OAuth token (JSON string, single line) ────────────────
# In Streamlit Cloud put this in secrets.toml as GOOGLE_TOKEN_JSON instead.
GOOGLE_TOKEN_JSON=
# Local-dev fallback path; only used if GOOGLE_TOKEN_JSON unset.
GOOGLE_TOKEN_PATH=token.json

# ── Postgres for LangGraph checkpointer ───────────────────────────────────
# Leave empty to fall back to in-memory (DEV ONLY — conversations are lost
# on restart). Set this in production.
DATABASE_URL=postgresql://esmi:esmi@localhost:5432/esmi
# Optional: pool size (default 10)
DB_POOL_SIZE=10

# ── LangSmith / LangChain tracing ─────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=esmi-receptionist
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── SendGrid (booking notification email) ─────────────────────────────────
SENDGRID_API_KEY=

# ── Twilio (SMS + WhatsApp webhook) ───────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ── Knowledge base ────────────────────────────────────────────────────────
# Source markdown dir. Default works with current repo layout.
KB_SOURCE_DIR=orchelix_knowledge_base
# Where the persisted FAISS index lives. Auto-rebuilds when KB content changes.
KB_INDEX_DIR=.kb_index
